\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jpdv}[2024/02/07 Derivatives and Differentials]

\newif\ifjp@dv@upright
\newif\ifjp@dv@defp
\jp@dv@defpfalse
\jp@dv@uprightfalse
\DeclareOption{upright}{\jp@dv@uprighttrue}
\DeclareOption{partial}{\jp@dv@defptrue}
\ProcessOptions\relax

\RequirePackage{xstring}
\RequirePackage{xparse}

\ifjp@dv@upright
	\newsavebox\jp@dv@unslant@box

	\NewDocumentCommand{\jp@dv@unslant}{som}{%
		{%
			\mbox{%
				\sbox{\jp@dv@unslant@box}{$#3$}%
				\hskip\wd\jp@dv@unslant@box%
				\pdfsave%
				\IfBooleanTF{#1}{%
					\IfValueTF{#2}{%
						\expandafter\pdfsetmatrix{1 #2 0 1}%
					}{%
						\pdfsetmatrix{1 -.25 0 1}%
					}%
				}{%
					\IfValueTF{#2}{%
						\expandafter\pdfsetmatrix{1 0 #2 1}%
					}{%
						\pdfsetmatrix{1 0 -.25 1}%
					}%
				}%
				\llap{\usebox{\jp@dv@unslant@box}}%
				\pdfrestore%
			}%
			\kern-0.8pt
		}%
	}
\fi

% Defines jp@IsInteger macro if it doesn't exist.
\ifcsname jp@IsInteger\endcsname\else
	\newcommand*{\jp@IsInteger}[3]{%
		\edef\jp@IsInteger@tmp{\expandafter\detokenize\expandafter{#1}}%
		\IfStrEq{\jp@IsInteger@tmp}{ }{%
			#3%
		}{%
			\IfInteger{\jp@IsInteger@tmp}{#2}{#3}%
		}%
	}%
\fi

\ifcsname df\endcsname
  \PackageError{jpdv}{Command df is already defined}
\fi
\ifcsname dv\endcsname
  \PackageError{jpdv}{Command dv is already defined}
\fi

\ifjp@dv@upright
	\newcommand\dvsetupright{%
		\gdef \jp@dv@chrs@d {\mathrm{d}}%
		\gdef \jp@dv@chrs@D {\mathrm{D}}%
		\gdef \jp@dv@chrs@e {\jp@dv@unslant{\delta}}%
		\gdef \jp@dv@chrs@p {\jp@dv@unslant{\partial}}%
	}
\fi
\newcommand\dvsetnormal{%
  \gdef \jp@dv@chrs@d {d}%
  \gdef \jp@dv@chrs@D {D}%
  \gdef \jp@dv@chrs@e {\delta}%
  \gdef \jp@dv@chrs@p {\partial}%
}
\gdef \jp@dv@chrs@E {\Delta}%

\gdef\jp@dv@chrsspac@d{}
\gdef\jp@dv@chrsspac@D{}
\gdef\jp@dv@chrsspac@e{}
\gdef\jp@dv@chrsspac@E{\!}
\gdef\jp@dv@chrsspac@p{}

\def\jp@dv@dfchar #1{%
  \edef\arg{\detokenize{#1}}%
  % If empty, do default
  \if\relax\arg\relax%
    % default is d.
		\ifjp@dv@defp%
			\jp@dv@chrs@p%
		\else%
			\jp@dv@chrs@d%
		\fi%
  \else%
    \ifcsname jp@dv@chrs@\arg\endcsname%
      \csname jp@dv@chrs@\arg\endcsname%
    \else%
      \PackageError{jpdv}{Unknown Character Argument}%
    \fi%
  \fi%
}%

\def\jp@dv@dfcharspac #1{%
  \edef\arg{\detokenize{#1}}%
  % If empty, do default
  \if\relax\arg\relax%
    % default is d.
		\ifjp@dv@defp%
			\jp@dv@chrsspac@p%
		\else%
			\jp@dv@chrsspac@d%
		\fi%
  \else%
    \ifcsname jp@dv@chrsspac@\arg\endcsname%
      \csname jp@dv@chrsspac@\arg\endcsname%
    \else%
      \PackageError{jpdv}{Unknown Character Argument}%
    \fi%
  \fi%
}%

\def\jp@dv@prt{%
	\advance\jp@dv@idx by -1\relax%
	\advance\jp@dv@leftidx by 1\relax%
	\ifjp@dv@didexp^\fi{\StrMid{\jp@dv@arg}{\the\jp@dv@leftidx}{\the\jp@dv@idx}}%
	\advance\jp@dv@idx by 1\relax%
	\jp@dv@leftidx=\jp@dv@idx%
}%

\newcount\jp@dv@idx
\newcount\jp@dv@leftidx
\newif\ifjp@dv@didexp
\newif\ifjp@dv@wassemicol
\newif\ifjp@dv@indv
\jp@dv@indvfalse

\NewDocumentCommand{\df}{sm!o!s}{%
	\expandarg%
  \ensuremath{%
    % Get character argument
    \ifjp@dv@indv\else%
			\edef\jp@dv@chararg{\IfBooleanTF{#4}{\ifjp@dv@defp d\else p\fi}{\IfValueT{#3}{#3}}}%
      \def\jp@dv@char{%
        \expandafter\jp@dv@dfchar\jp@dv@chararg{}%
      }%
    \fi%
		\def\jp@dv@arg{#2}%
    % Get argument length
    \StrLen{#2}[\arglen]%
    \ifnum\arglen=0\relax%
      \PackageError{jpdv}{Empty Argument in Differential}%
    \fi%
    \jp@dv@idx=1%
    \jp@dv@leftidx=0%
    \jp@dv@didexpfalse%
    \loop%
    \StrChar{#2}{\the\jp@dv@idx}[\thc]%
    \if\thc,%
			\ifjp@dv@didexp\else%
				\jp@dv@char%
			\fi%
			\jp@dv@prt%
			\IfBooleanF{#1}{\,}%
      \jp@dv@didexpfalse%
    \else%
      \if\thc;%
				\jp@dv@char%
				\jp@dv@prt%
        \jp@dv@didexptrue%
				\jp@dv@wassemicoltrue%
      \else%
				\jp@IsInteger{\thc}{%
					\ifjp@dv@didexp\else%
						\jp@dv@char%
						\jp@dv@prt%
						\advance\jp@dv@leftidx by -1\relax%
						\jp@dv@didexptrue%
						\jp@dv@wassemicolfalse%
					\fi%
				}{%
					\ifjp@dv@didexp%
						\ifjp@dv@wassemicol\else%
							\jp@dv@prt%
							\IfBooleanF{#1}{\,}%
							\advance\jp@dv@leftidx by -1\relax%
							\jp@dv@didexpfalse%
						\fi%
					\fi%
				}%
      \fi%
    \fi%
    \advance\jp@dv@idx by 1\relax%
    \ifnum\jp@dv@idx > \arglen\relax%
    \else \repeat%
		\ifjp@dv@didexp\else%
			\jp@dv@char%
		\fi%
		\jp@dv@prt%
  }%
}%

\newif\ifjp@dv@nonint
\newif\ifjp@dv@endloop
\newcount\jp@dv@expcount

\newcommand{\jp@dv@countexp}[1]{%
	\expandarg%
  \StrLen{#1}[\arglen]%
  \ifnum\arglen=0\relax%
    \PackageError{jpdv}{Empty Argument in Differential}%
  \fi%
  \jp@dv@idx=1%
  \jp@dv@expcount=0%
  \jp@dv@didexpfalse%
  \jp@dv@nonintfalse%
  \loop%
  \StrChar{#1}{\the\jp@dv@idx}[\thc]%
  \if\thc,%
    \ifjp@dv@didexp%
      \advance \jp@dv@leftidx by 1\relax%
      \advance \jp@dv@idx by -1\relax%
      \StrMid{#1}{\the\jp@dv@leftidx}{\the\jp@dv@idx}[\intstr]%
      \jp@IsInteger{\intstr}{%
        \advance \jp@dv@expcount by \intstr\relax%
      }%
      {%
        \jp@dv@noninttrue%
      }%
      \advance \jp@dv@idx by 1\relax%
    \else%
      \advance \jp@dv@expcount by 1\relax%
    \fi%
    \jp@dv@didexpfalse%
  \else%
    \if\thc;%
      \jp@dv@didexptrue%
      \jp@dv@leftidx=\jp@dv@idx%
			\jp@dv@wassemicoltrue%
    \else%
			\jp@IsInteger{\thc}{%
				\ifjp@dv@didexp\else%
					\jp@dv@leftidx=\jp@dv@idx%
					\advance\jp@dv@leftidx by -1\relax%
					\jp@dv@didexptrue%
					\jp@dv@wassemicolfalse%
				\fi%
			}{%
				\ifjp@dv@didexp%
					\ifjp@dv@wassemicol\else%
						\advance \jp@dv@leftidx by 1\relax%
						\advance\jp@dv@idx by -1\relax%
						\StrMid{#1}{\the\jp@dv@leftidx}{\the\jp@dv@idx}[\intstr]%
						\advance\jp@dv@idx by 1\relax%
						\jp@dv@leftidx=\jp@dv@idx%
						\advance\jp@dv@leftidx by -1\relax%
						\jp@IsInteger{\intstr}{%
							\advance \jp@dv@expcount by \intstr\relax%
						}%
						{%
							\jp@dv@noninttrue%
						}%
						\jp@dv@didexpfalse%
					\fi%
				\fi%
			}%
    \fi%
  \fi%
  \advance\jp@dv@idx by 1\relax%
  \ifnum\jp@dv@idx > \arglen\relax%
    \jp@dv@endlooptrue%
  \else%
    \jp@dv@endloopfalse%
  \fi%
  \ifjp@dv@nonint%
    \jp@dv@endlooptrue%
  \fi%
  \ifjp@dv@endloop \else \repeat%
  \ifjp@dv@nonint%
  \else%
    \ifjp@dv@didexp%
      \advance \jp@dv@leftidx by 1\relax%
      \advance \jp@dv@idx by -1\relax%
      \StrMid{#1}{\the\jp@dv@leftidx}{\the\jp@dv@idx}[\intstr]%
      \jp@IsInteger{\intstr}{%
        \advance \jp@dv@expcount by \intstr\relax%
      }%
      {%
        ^{\StrMid{#1}{\the\jp@dv@leftidx}{\the\jp@dv@idx}[\expstr]}%
        \jp@dv@noninttrue%
      }%
    \else%
      \advance \jp@dv@expcount by 1\relax%
    \fi%
  \fi%
  \ifjp@dv@nonint%
  \else%
    \ifnum\jp@dv@expcount > 1\relax%
      ^{\jp@dv@charspac\the\jp@dv@expcount}%
    \fi%
  \fi%
}%

\NewDocumentCommand{\dv}{soom!o!s}{%
	\expandarg%
  \ensuremath{%
    \edef\jp@dv@chararg{\IfBooleanTF{#6}{\ifjp@dv@defp d\else p\fi}{\IfValueT{#5}{#5}}}%
    \def\jp@dv@char{%
      \expandafter\jp@dv@dfchar\jp@dv@chararg{}%
    }%
		\def\jp@dv@charspac{%
			\expandafter\jp@dv@dfcharspac\jp@dv@chararg{}%
		}%
    \IfBooleanF{#1}{\frac}%
    {%
      \jp@dv@char%
      \IfValueTF{#3}%
      {%
        ^{\jp@dv@charspac#3}%
      }%
      {%
        \jp@dv@countexp{#4}%
      }%
			{\IfValueT{#2}{#2}}%
      \IfBooleanT{#1}{/}%
    }%
    {%
			\jp@dv@indvtrue
      \df*{#4}%
			\jp@dv@indvfalse
    }%
  }%
}%

